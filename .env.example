# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# For server-side operations that bypass RLS (keep this secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Twitch stream status ──────────────────────────────────────────────────────
# Create a Twitch app at: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ─── YouTube stream status ─────────────────────────────────────────────────────
# Create an API key at: https://console.cloud.google.com (YouTube Data API v3)
YOUTUBE_API_KEY=
# Your channel's ID (found in YouTube Studio > Settings > Channel > Advanced)
YOUTUBE_CHANNEL_ID=

# Note: Kick status is checked via public API — no key required.
